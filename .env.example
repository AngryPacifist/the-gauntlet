# Database connection string (Neon, Supabase, or local Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Backend server port
PORT=3001

# Adrena API base URL
ADRENA_API_URL=https://datapi.adrena.trade

# Admin secret (for protected admin endpoints)
ADMIN_SECRET=change-me-to-a-random-string

# Helius RPC URL (optional, for Solana RPC access)
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-key-here
